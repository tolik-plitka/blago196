---
import Layout from '~/layouts/Layout.astro';

import HeroSection from '~/components/HeroSection.astro';
import ServicesSection from '~/components/ServicesSection.astro';
import WhyUsSection from '~/components/WhyUsSection.astro';
import PortfolioSection from '~/components/PortfolioSection.astro';
import ReviewsSection from '~/components/ReviewsSection.astro';
import ContactSection from '~/components/ContactSection.astro';
import Footer from '~/components/widgets/Footer.astro';
import { footerData } from '~/navigation';

import { Phone } from '@lucide/astro';

const metadata = {
  title: 'Турсунали blago196 - Профессиональная укладка плитки в Екатеринбурге',
  description:
    'Укладка тротуарной плитки под ключ в Екатеринбурге и области. Гарантия качества, доступные цены. Звоните: +7 925 222 41 90.',
  ignoreTitleTemplate: false,
};
---

<Layout metadata={metadata}>
  <!-- Structured Data для SEO -->
  <script
    type="application/ld+json"
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'LocalBusiness',
      name: 'Турсунали blago196',
      description: 'Профессиональная укладка тротуарной плитки под ключ',
      telephone: '+79252224190',
      address: {
        '@type': 'PostalAddress',
        streetAddress: 'Екатеринбург',
        addressLocality: 'Екатеринбург',
        addressRegion: 'Свердловская область',
        addressCountry: 'RU',
      },
      url: 'https://blago196.ru',
      image: 'https://blago196.ru/og-image.jpg',
      areaServed: ['Екатеринбург', 'Свердловская область'],
      serviceType: 'Благоустройство территории',
    })}
  />

  <HeroSection />
  <ServicesSection />
  <WhyUsSection />
  <PortfolioSection />
  <ReviewsSection />
  <ContactSection />
  <Footer {...footerData} />

  <!-- Floating Phone Button -->
  <a
    href="tel:+79252224190"
    class="fixed bottom-6 right-6 z-50 w-16 h-16 bg-orange-500 hover:bg-orange-600 rounded-full flex items-center justify-center shadow-2xl phone-pulse transition-transform hover:scale-110"
    aria-label="Позвонить"
  >
    <Phone class="w-7 h-7 text-white" />
  </a>
</Layout>

<style>
  .phone-pulse {
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%,
    100% {
      box-shadow: 0 0 0 0 rgba(234, 88, 12, 0.4);
    }
    50% {
      box-shadow: 0 0 0 15px rgba(234, 88, 12, 0);
    }
  }
</style>
